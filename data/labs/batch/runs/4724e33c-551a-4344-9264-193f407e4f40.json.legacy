      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":8903,\"status\":\"ok\",\"attempts\":2},{\"step\":\"creation_planner\",\"ms\":15043,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":2,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":44419,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":175417,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"planner\":\"v2\",\"vertical\":\"v2\",\"platform\":\"v2\",\"sp2\":\"v2\"}}",
