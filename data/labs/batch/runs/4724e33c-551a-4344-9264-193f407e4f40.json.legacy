      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":6234,\"status\":\"ok\",\"attempts\":2},{\"step\":\"creation_planner\",\"ms\":4471,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":13,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":66401,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":661709,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"planner\":\"v2\",\"vertical\":\"v2\",\"platform\":\"v2\",\"sp2\":\"v2\"}}",
