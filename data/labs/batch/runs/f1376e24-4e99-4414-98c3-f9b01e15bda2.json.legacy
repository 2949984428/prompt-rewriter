      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":1500,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":3,\"status\":\"ok\",\"attempts\":1},{\"step\":\"creation_planner\",\"ms\":30150,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":47857,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":1045705,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"vertical\":\"v2\",\"platform\":\"v2\",\"planner\":\"v1\",\"sp2\":\"v2\"}}",
