      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":1666,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":3,\"status\":\"ok\",\"attempts\":1},{\"step\":\"creation_planner\",\"ms\":1760,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":44851,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":66636,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"vertical\":\"v2\",\"platform\":\"v2\",\"planner\":\"v2\",\"sp2\":\"v2\"}}",
