      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":3629,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":5,\"status\":\"ok\",\"attempts\":1},{\"step\":\"creation_planner\",\"ms\":7685,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":93226,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":1045433,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"vertical\":\"v2\",\"platform\":\"v2\",\"planner\":\"v1\",\"sp2\":\"v2\"}}",
