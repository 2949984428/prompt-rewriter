      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":3870,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":5,\"status\":\"ok\",\"attempts\":1},{\"step\":\"creation_planner\",\"ms\":3516,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":35097,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":275651,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"vertical\":\"v2\",\"platform\":\"v2\",\"planner\":\"v1\",\"sp2\":\"v2\"}}",
