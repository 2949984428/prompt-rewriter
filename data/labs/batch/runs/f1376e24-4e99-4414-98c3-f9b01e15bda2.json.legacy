      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":8217,\"status\":\"ok\",\"attempts\":2},{\"step\":\"strategy_pack\",\"ms\":4,\"status\":\"ok\",\"attempts\":1},{\"step\":\"creation_planner\",\"ms\":8922,\"status\":\"ok\",\"attempts\":1},{\"step\":\"media_review\",\"ms\":50873,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":1041846,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"vertical\":\"v2\",\"platform\":\"v2\",\"planner\":\"v2\",\"sp2\":\"v2\"}}",
