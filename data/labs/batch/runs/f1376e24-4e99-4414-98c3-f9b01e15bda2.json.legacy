      "raw": "{\"trace\":[{\"step\":\"search_intent\",\"ms\":3791,\"status\":\"ok\",\"attempts\":1},{\"step\":\"strategy_pack\",\"ms\":7,\"status\":\"ok\",\"attempts\":1},{\"step\":\"creation_planner\",\"ms\":16170,\"status\":\"ok\",\"attempts\":2},{\"step\":\"media_review\",\"ms\":47314,\"status\":\"ok\",\"attempts\":1},{\"step\":\"generate_media\",\"ms\":243025,\"status\":\"ok\",\"attempts\":1}],\"strategy_versions\":{\"sp1\":\"v1\",\"vertical\":\"v2\",\"platform\":\"v2\",\"planner\":\"v1\",\"sp2\":\"v2\"}}",
