# ─── Prompt 改写器 LLM 网关 ───
LLM_BASE_URL=http://llm-gateway-go.svc.pre.lovart.cloud/v1
LLM_API_KEY=sk-placeholder
LLM_MODEL=bedrock/claude-sonnet-4-6

# ─── 生图网关(api-svc-go) ───
# 公司内网服务,与 LLM 网关走同一套 Clash bypass / VPN 规则
IMAGE_GATEWAY_BASE_URL=http://api-svc-pre-go.lovart.cloud
# baggage 里的 agent.service_name,用于链路追踪 / 计费
IMAGE_SERVICE_NAME=prompt-rewriter
# 图像模型名(网关路径里 `/openai/<IMAGE_MODEL>/text-to-image` 的 <model> 段)
# 切换其他模型需保证网关已挂载该模型,且对应 model profile 在 data/model_profiles/ 下
IMAGE_MODEL=gpt-image-2
