# ─── LLM 网关（OpenAI 兼容接口） ───
# 任何 OpenAI-compatible endpoint 都行：OpenAI、OpenRouter、自建 vLLM、Ollama 等
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# ─── 生图网关（OpenAI Images / gpt-image-2 兼容接口，可选） ───
# 不填则只能跑改写，不能出图
IMAGE_GATEWAY_BASE_URL=https://api.openai.com
IMAGE_SERVICE_NAME=prompt-rewriter
# 图像模型名（网关路径里 `/openai/<IMAGE_MODEL>/text-to-image` 的 <model> 段）
# 切其他模型需保证网关已挂载该模型，且 data/model_profiles/ 下有对应 profile
IMAGE_MODEL=gpt-image-2

# ─── Cloudflare R2（可选，仅 batch 实验台导出 CSV → 公网图片 URL 时需要） ───
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://pub-<id>.r2.dev
